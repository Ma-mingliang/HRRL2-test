<?xml version="1.0" encoding="UTF-8"?>
<robot name="continuous_s_curves">
  <!-- Continuous S-Curves Terrain - 4 curves with 8m radius -->
  
  <!-- Segment 0: friction=0.90 -->
  <link name="segment_0">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="adaptive_terrain_continuous_s_curves_varying.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="mat_0">
        <color rgba="0.2 0.8 0.2 1.0"/>
      </material>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="adaptive_terrain_continuous_s_curves_varying.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <contact>
        <lateral_friction value="0.9"/>
        <rolling_friction value="0.09000000000000001"/>
        <spinning_friction value="0.045000000000000005"/>
      </contact>
    </collision>
    
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" 
               iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
  
  <!-- Segment 1: friction=0.60 -->
  <link name="segment_1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="adaptive_terrain_continuous_s_curves_varying.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="mat_1">
        <color rgba="0.8 0.6 0.2 1.0"/>
      </material>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="adaptive_terrain_continuous_s_curves_varying.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <contact>
        <lateral_friction value="0.6"/>
        <rolling_friction value="0.06"/>
        <spinning_friction value="0.03"/>
      </contact>
    </collision>
    
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" 
               iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
  
  <!-- Segment 2: friction=0.30 -->
  <link name="segment_2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="adaptive_terrain_continuous_s_curves_varying.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="mat_2">
        <color rgba="0.7 0.9 1.0 0.8"/>
      </material>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="adaptive_terrain_continuous_s_curves_varying.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <contact>
        <lateral_friction value="0.3"/>
        <rolling_friction value="0.03"/>
        <spinning_friction value="0.015"/>
      </contact>
    </collision>
    
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" 
               iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
  
  <!-- Segment 3: friction=0.70 -->
  <link name="segment_3">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="adaptive_terrain_continuous_s_curves_varying.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="mat_3">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="adaptive_terrain_continuous_s_curves_varying.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <contact>
        <lateral_friction value="0.7"/>
        <rolling_friction value="0.06999999999999999"/>
        <spinning_friction value="0.034999999999999996"/>
      </contact>
    </collision>
    
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" 
               iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
  
</robot>
