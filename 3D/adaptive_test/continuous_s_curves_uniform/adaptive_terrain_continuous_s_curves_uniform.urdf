<?xml version="1.0" encoding="UTF-8"?>
<robot name="continuous_s_curves">
  <!-- Continuous S-Curves Terrain - 4 curves with 8m radius -->
  
  <!-- Segment 0: friction=0.80 -->
  <link name="segment_0">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="adaptive_terrain_continuous_s_curves_uniform.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="mat_0">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="adaptive_terrain_continuous_s_curves_uniform.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <contact>
        <lateral_friction value="0.8"/>
        <rolling_friction value="0.08000000000000002"/>
        <spinning_friction value="0.04000000000000001"/>
      </contact>
    </collision>
    
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" 
               iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
  
</robot>
