<?xml version="1.0" encoding="UTF-8"?>
<robot name="continuous_s_curves">
  <!-- Continuous S-Curves Terrain - 4 curves with 8m radius -->
  
  <!-- Segment 0: friction=0.85 -->
  <link name="segment_0">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="adaptive_terrain_continuous_s_curves_gradient.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="mat_0">
        <color rgba="0.0 0.8 0.0 1.0"/>
      </material>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="adaptive_terrain_continuous_s_curves_gradient.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <contact>
        <lateral_friction value="0.85"/>
        <rolling_friction value="0.085"/>
        <spinning_friction value="0.0425"/>
      </contact>
    </collision>
    
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" 
               iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
  
  <!-- Segment 1: friction=0.50 -->
  <link name="segment_1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="adaptive_terrain_continuous_s_curves_gradient.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="mat_1">
        <color rgba="0.8 0.8 0.0 1.0"/>
      </material>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="adaptive_terrain_continuous_s_curves_gradient.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <contact>
        <lateral_friction value="0.5"/>
        <rolling_friction value="0.05"/>
        <spinning_friction value="0.025"/>
      </contact>
    </collision>
    
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" 
               iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
  
  <!-- Segment 2: friction=0.20 -->
  <link name="segment_2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="adaptive_terrain_continuous_s_curves_gradient.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="mat_2">
        <color rgba="0.8 0.9 1.0 0.7"/>
      </material>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="adaptive_terrain_continuous_s_curves_gradient.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <contact>
        <lateral_friction value="0.2"/>
        <rolling_friction value="0.020000000000000004"/>
        <spinning_friction value="0.010000000000000002"/>
      </contact>
    </collision>
    
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" 
               iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
  
  <!-- Segment 3: friction=0.75 -->
  <link name="segment_3">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="adaptive_terrain_continuous_s_curves_gradient.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="mat_3">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="adaptive_terrain_continuous_s_curves_gradient.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <contact>
        <lateral_friction value="0.75"/>
        <rolling_friction value="0.07500000000000001"/>
        <spinning_friction value="0.037500000000000006"/>
      </contact>
    </collision>
    
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" 
               iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
  
</robot>
