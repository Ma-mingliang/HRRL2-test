<?xml version="1.0"?>
<robot name="s_line_terrain">
  <!-- S型路径地形 -->
  
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="s_line_path.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="orange">
        <color rgba="1.0 0.6 0.0 0.8"/>
      </material>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="s_line_path.obj" scale="1.0 1.0 1.0"/>
      </geometry>
    </collision>
    
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" 
               iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>
  
</robot>
